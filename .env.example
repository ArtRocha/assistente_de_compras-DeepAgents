# =============================================
# Assistente de Compras - Variáveis de Ambiente
# =============================================

# --- Ollama (Agentes de IA - Local e Gratuito) ---
# Instale o Ollama em https://ollama.com e rode: ollama pull llama2:7b
# Para usar outro modelo: ollama pull mistral  →  OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2:7b

# --- SerpAPI (OBRIGATÓRIO para buscas reais) ---
# Obter chave gratuita em: https://serpapi.com
# Plano gratuito: 100 buscas/mês
# Sem esta chave, o sistema retorna lista vazia de produtos.
SERPAPI_KEY=your_serpapi_key_here

# --- MongoDB (opcional, para cache de validação) ---
# Se não definido, o cache fica desabilitado (validações repetidas sem cache)
# MONGO_URI=mongodb://localhost:27017

# --- Limites do Orquestrador (opcionais) ---
# ORCHESTRATOR_MAX_CONCURRENT_WORKFLOWS=2
# ORCHESTRATOR_MAX_PRODUCTS_FOR_VALIDATION=30
# TRUST_MAX_CONCURRENCY=6
